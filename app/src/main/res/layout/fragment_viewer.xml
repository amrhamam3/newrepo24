<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- GL Viewer -->
    <com.amr3d.preview.pro.GLViewerView
        android:id="@+id/glViewerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <!-- Empty State -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/emptyContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/dark_bg">
            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁 افتح ملف STL أو DXF"
                android:textSize="16sp"
                android:textColor="@color/light_text" />
        </LinearLayout>
        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="40dp"
            android:textSize="14sp"
            android:textColor="@color/accent_orange"
            android:visibility="gone" />
        <TextView
            android:id="@+id/welcomeOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="20sp"
            android:textColor="@color/accent_orange"
            android:gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/dark_surface"
        android:gravity="center_vertical">
        <Button
            android:id="@+id/btnOpenFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📂 افتح ملف"
            style="?attr/buttonBarButtonStyle" />
        <ImageButton
            android:id="@+id/btnWhatsapp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="WhatsApp" />
    </LinearLayout>

    <!-- Display Toolbar -->
    <LinearLayout
        android:id="@+id/displayToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/dark_surface"
        android:gravity="center">
        <ImageButton
            android:id="@+id/btnWireframe"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Wireframe" />
        <ImageButton
            android:id="@+id/btnMaterial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Material" />
        <ImageButton
            android:id="@+id/btnMeasureTool"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Measure" />
        <ImageButton
            android:id="@+id/btnInspect"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Inspect" />
        <ImageButton
            android:id="@+id/btnResetView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Reset" />
        <ImageButton
            android:id="@+id/btnLightToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Light" />
        <ImageButton
            android:id="@+id/btnExport"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Export" />
    </LinearLayout>

    <!-- Bottom Toolbar -->
    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/dark_surface"
        android:gravity="center">
        <Button
            android:id="@+id/btnUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📏 MM"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnDirections"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧭 Views"
            style="?attr/buttonBarButtonStyle" />
    </LinearLayout>

    <!-- Directions Panel -->
    <LinearLayout
        android:id="@+id/directionsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/dark_surface"
        android:gravity="center"
        android:visibility="gone">
        <Button
            android:id="@+id/btnViewFront"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Front"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnViewBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnViewLeft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Left"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnViewRight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Right"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnViewTop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Top"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
        <Button
            android:id="@+id/btnViewBottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bottom"
            android:textSize="10sp"
            style="?attr/buttonBarButtonStyle" />
    </LinearLayout>

    <!-- Light Wheel Container -->
    <FrameLayout
        android:id="@+id/lightWheelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_surface"
        android:visibility="gone">
        <com.amr3d.preview.pro.SemiCircleLightView
            android:id="@+id/lightWheel"
            android:layout_width="match_parent"
            android:layout_height="140dp" />
        <ImageButton
            android:id="@+id/btnCloseLightWheel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_gravity="end|center_vertical"
            android:layout_margin="8dp"
            android:contentDescription="Close" />
    </FrameLayout>

    <!-- Measurement Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/measurementCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/dark_surface"
        app:cardElevation="4dp">
        <TextView
            android:id="@+id/measurementText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="@color/light_text"
            android:textSize="14sp" />
    </androidx.cardview.widget.CardView>

    <!-- Inspection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inspectionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/dark_surface"
        app:cardElevation="4dp">
        <TextView
            android:id="@+id/inspectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="@color/light_text"
            android:textSize="14sp" />
    </androidx.cardview.widget.CardView>

    <!-- Loading Container -->
    <FrameLayout
        android:id="@+id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="100dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center">
            <ProgressBar
                android:id="@+id/loadingProgress"
                android:layout_width="60dp"
                android:layout_height="60dp"
                style="?attr/progressBarStyle" />
            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="جارٍ التحميل..."
                android:textColor="@color/light_text"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
