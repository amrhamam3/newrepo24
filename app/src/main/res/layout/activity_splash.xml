<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- خلفية Wireframe ثلاثية الأبعاد -->
    <com.amr3d.preview.pro.WireframeSplashView
        android:id="@+id/wireframeAnim"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- محتوى مركزي — مرفوع للأعلى -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="80dp">

        <!-- حاوية اللوجو + الحلقة — أكبر -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <!-- الحلقة الدوّارة -->
            <com.amr3d.preview.pro.RingView
                android:id="@+id/splashRingView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- اللوجو بدون خلفية — شفاف تماماً -->
            <ImageView
                android:id="@+id/splashLogo"
                android:layout_width="172dp"
                android:layout_height="172dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:contentDescription="Amr Hamam 3D"
                android:background="@android:color/transparent" />

        </FrameLayout>

        <!-- اسم التطبيق -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AMR3D PREVIEW"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp" />

        <!-- النص المتغير -->
        <TextView
            android:id="@+id/splashDev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO START"
            android:textColor="#FF8A1E"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="48dp" />

        <!-- شريط التحميل -->
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal">

            <TextView
                android:id="@+id/splashProgressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="0%"
                android:textColor="#FF8A1E"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/splashProgress"
                style="@style/SplashProgressBar"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="0" />

        </LinearLayout>

    </LinearLayout>

    <!-- اسم التطبيق في أسفل الشاشة -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="Amr3D Preview Pro · Amr Hamam"
        android:textColor="#444444"
        android:textSize="10sp"
        android:letterSpacing="0.1" />

</FrameLayout>
